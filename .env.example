# Resend API key for the demo-request form (https://resend.com).
# If unset, the /api/demo route logs submissions to the console and returns success.
RESEND_API_KEY=your_resend_api_key_here

# Optional: verified Resend "from" sender. Defaults to onboarding@resend.dev.
# Use a verified grably.ca address in production, e.g. "Grably <demos@grably.ca>".
DEMO_FROM=Grably <onboarding@resend.dev>
